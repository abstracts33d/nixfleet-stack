          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Response Time p95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by(handler, le) (rate(caddy_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ handler }} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "noValue": "0",
          "color": {
            "mode": "palette-classic"
