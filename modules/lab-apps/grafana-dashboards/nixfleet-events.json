{
  "uid": "nixfleet-events",
  "title": "NixFleet Events",
  "description": "Operator-first event observability for v0.2 nixfleet. Top: health snapshot. Then: live activity, failures + recovery, compliance audit, cert lifecycle, gate decisions, probe activity, per-rollout drill-down, reference counters. Sourced from CP + agent journald JSON tracing (Loki) and CP Prometheus counters.",
  "schemaVersion": 39,
  "version": 1,
  "tags": [
    "nixfleet",
    "v0.2"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(up{job=\"node\"}, instance)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": true
        },
        "options": [],
        "hide": 0,
        "regex": "/^(.+?):/"
      },
      {
        "name": "rollout",
        "label": "Rollout ID",
        "description": "Free-text rollout ID for the per-rollout drill-down (Section VIII). Format: edge@<commit> or stable@<commit>.",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": "",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
