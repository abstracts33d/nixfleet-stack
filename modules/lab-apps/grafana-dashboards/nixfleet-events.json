    {
      "id": 112,
      "title": "ProbeResult events carrying overrideReason",
      "description": "ProbeResult sub_results carries effectiveMode + overrideReason per (control, framework, article). Operator-declared reason text from fleet.nix rides verbatim onto the signed event_log payload \u2014 auditors recover 'why was this control downgraded?' from the chain alone.",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-control-plane.service\"} | json | line_format \"{{.message}}\" | json | target = `events` |~ `ProbeResult` |~ `overrideReason` | line_format \"[{{.fields_hostname}}] probe={{.fields_probe_name}} rollout={{.fields_rollout_id}}\"",
          "queryType": "range",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "V. Cert + trust lifecycle (renewals, revocations, enrollment nonces)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 113,
      "title": "Agent cert renewals",
      "description": "60s ticker on agents. Reads cert validity; calls /v1/agent/renew when below renewalThresholdFraction. Atomic file replacement; in-memory mTLS clients pick up new cert on next agent restart.",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-agent.service\"} | json | line_format \"{{.message}}\" | json |~ `cert remaining fraction below threshold|renewed - wrote cert|enrolled - wrote cert` | line_format \"[{{.host}}] {{.fields_message}} remaining={{.fields_remaining}} not_after={{.fields_not_after}}\"",
          "queryType": "range",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 114,
      "title": "Signed-sidecar polls (revocations + bootstrap nonces)",
      "description": "60s polls of revocations.json + bootstrap-nonces.json (signed sidecars in fleet.git/releases/). Replays into cert_revocations + bootstrap_nonces in-memory allowlists. Empty allowlist => /v1/enroll refuses all; revoked host's mTLS rejected at handshake.",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-control-plane.service\"} | json | line_format \"{{.message}}\" | json | target =~ `revocations|bootstrap_nonces` | line_format \"{{.fields_target}}: {{.fields_message}} entries={{.fields_entries}}\"",
          "queryType": "range",
          "maxLines": 200
        }
      ],
      "options": {
