    {
      "id": 108,
      "title": "State transitions (CP reducer)",
      "description": "Host + rollout state-machine transitions. Read top-down for the live shape of the fleet.",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-control-plane.service\"} | json | line_format \"{{.message}}\" | json | target = `cp_reducer` |~ `HostStateChanged|RolloutStateChanged|state transition|from.*to` | line_format \"[{{.fields_host}}] {{.fields_message}} rollout={{.fields_rollout_id}}\"",
          "queryType": "range",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
