    {
      "id": 100,
      "title": "Dispatches (1h)",
      "description": "POST /v1/agent/dispatch \u2014 manifests delivered to agents.",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "sum(count_over_time({unit=\"nixfleet-control-plane.service\"} | json | line_format `{{.message}}` | json | target = `dispatch` [1h]))",
          "queryType": "instant",
          "instant": null,
          "format": null
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "graphMode": "area",
        "justifyMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
