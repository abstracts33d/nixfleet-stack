    {
      "id": 110,
      "title": "Rollback firings (agent \u2192 switch-to-configuration)",
      "description": "onHealthFailure = rollback-and-halt fires. Detached systemd-run runs switch-to-configuration on the prior closure; agent SIGTERMs mid-poll.",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-agent.service\"} | json | line_format \"{{.message}}\" | json |~ `triggering local rollback|switching profile|rollback target discovered` | line_format \"[{{.host}}] {{.fields_message}} target={{.fields_target_basename}}\"",
          "queryType": "range",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 111,
      "title": "Auto-recovery (Failed \u2192 Reverted synth)",
      "description": "CP synthesises the missing RollbackComplete event when post-rollback heartbeat reports current_closure == pre-dispatch closure. Closes the agent-SIGTERM gap that previously left hosts stuck in Failed.",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
