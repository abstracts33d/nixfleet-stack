{
  "id": null,
  "uid": "fleet-overview",
  "title": "Fleet Overview",
  "description": "Fleet-wide host health: CPU, memory, disk, network, uptime",
  "tags": [
    "fleet"
  ],
  "editable": false,
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 100,
      "title": "Status",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Host Status",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"node\", instance=~\"$host:.+\"}",
          "legendFormat": "{{ instance }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "N/A",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#ed8796",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "#a6da95",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#ed8796",
                "value": null
              },
              {
                "color": "#a6da95",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "links": [
            {
              "title": "View NixFleet events for ${__field.labels.hostname}",
              "url": "/d/nixfleet-events?var-hostname=${__field.labels.hostname}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "description": "Click any host to drill down to NixFleet Events."
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_time_seconds{instance=~\"$host:.+\"} - node_boot_time_seconds{instance=~\"$host:.+\"}",
          "legendFormat": "{{ instance }}",
          "instant": true
        }
