    {
      "id": 110,
      "type": "row",
      "title": "NixFleet activity (for $host)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 111,
      "title": "Reducer activity (rollout state for $host)",
      "description": "CP state-machine decisions affecting $host \u2014 HostStateChanged, dispatch, gate holds (channel-edges, wave-promotion, host-edges, disruption-budget, compliance-wave, quarantine), synth-converge.",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-control-plane.service\"} | json | line_format `{{.message}}` | json | target = `cp_reducer` | fields_host =~ \"${host}\"",
          "queryType": "range",
          "maxLines": 100
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 112,
      "title": "Cert lifecycle ($host)",
      "description": "CP-side issuance journal filtered to $host \u2014 first-boot enrollment + rotation worker renewals.",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-control-plane.service\"} | json | line_format `{{.message}}` | json | target = `issuance` |~ \"${host}\"",
          "queryType": "range",
          "maxLines": 100
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 113,
      "title": "Agent activity (rollback, activation, probe lifecycle for $host)",
      "description": "Agent-side activity on $host \u2014 rollback firings, activation switch-to-configuration, probe topology declarations on each closure switch, cert enroll/renew flow.",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-lab"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-lab"
          },
          "expr": "{unit=\"nixfleet-agent.service\"} |~ \"${host}\" |~ \"rollback|switching profile|ProbeTopologyDeclared|enrolled|renewed\"",
          "queryType": "range",
          "maxLines": 100
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
